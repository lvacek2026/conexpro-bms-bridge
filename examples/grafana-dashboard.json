{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Conexpro / JBD / Xiaoxiang Smart BMS — full-width Tesla/Victron-style overview. Live SoC bar, pack V/I/P, cell voltages with running delta, temperatures, state timeline, and meta footer. Designed against the schema written by node-red-contrib-influxdb from the conexpro-bms-bridge MQTT data, using the grafana-energy-viz colour semantics.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "type": "bargauge",
      "title": "State of charge",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 6 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_BMS}" },
      "targets": [
        {
          "refId": "A",
          "rawQuery": true,
          "query": "SELECT last(\"soc_pct\") FROM \"bms_live\" WHERE $timeFilter",
          "resultFormat": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#dc2626", "value": null },
              { "color": "#fb923c", "value": 20 },
              { "color": "#facc15", "value": 50 },
              { "color": "#16a34a", "value": 80 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "lcd",
        "showUnfilled": true,
        "valueMode": "color",
        "minVizWidth": 200,
        "minVizHeight": 16,
        "namePlacement": "hidden",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Pack voltage",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 3 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_BMS}" },
      "targets": [
        {
          "refId": "A",
          "rawQuery": true,
          "query": "SELECT last(\"voltage_v\") FROM \"bms_live\" WHERE $timeFilter",
          "resultFormat": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "volt",
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#dc2626", "value": null },
              { "color": "#fb923c", "value": 12.0 },
              { "color": "#16a34a", "value": 12.8 },
              { "color": "#fb923c", "value": 14.6 },
              { "color": "#dc2626", "value": 14.8 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "value",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Current",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 3 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_BMS}" },
      "targets": [
        {
          "refId": "A",
          "rawQuery": true,
          "query": "SELECT last(\"current_a\") FROM \"bms_live\" WHERE $timeFilter",
          "resultFormat": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "amp",
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#dc2626", "value": null },
              { "color": "#fb923c", "value": -100 },
              { "color": "#3b82f6", "value": -0.1 },
              { "color": "#6b7280", "value": 0 },
              { "color": "#16a34a", "value": 0.1 },
              { "color": "#fb923c", "value": 100 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "value",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Power",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 3 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_BMS}" },
      "targets": [
        {
          "refId": "A",
          "rawQuery": true,
          "query": "SELECT last(\"power_w\") FROM \"bms_live\" WHERE $timeFilter",
          "resultFormat": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#dc2626", "value": null },
              { "color": "#fb923c", "value": -2000 },
              { "color": "#3b82f6", "value": -0.1 },
              { "color": "#6b7280", "value": 0 },
              { "color": "#16a34a", "value": 0.1 },
              { "color": "#fb923c", "value": 2000 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "value",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Cell delta — now",
      "gridPos": { "x": 12, "y": 3, "w": 4, "h": 3 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_BMS}" },
      "targets": [
        {
          "refId": "A",
          "rawQuery": true,
          "query": "SELECT last(\"cell_delta_v\") * 1000 FROM \"bms_state\" WHERE $timeFilter",
          "resultFormat": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "mvolt",
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#16a34a", "value": null },
              { "color": "#facc15", "value": 30 },
              { "color": "#fb923c", "value": 80 },
              { "color": "#dc2626", "value": 150 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "value",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Cell delta — max in range",
      "gridPos": { "x": 16, "y": 3, "w": 4, "h": 3 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_BMS}" },
      "targets": [
        {
          "refId": "A",
          "rawQuery": true,
          "query": "SELECT max(\"cell_delta_v\") * 1000 FROM \"bms_state\" WHERE $timeFilter",
          "resultFormat": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "mvolt",
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#16a34a", "value": null },
              { "color": "#facc15", "value": 30 },
              { "color": "#fb923c", "value": 80 },
              { "color": "#dc2626", "value": 150 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "value",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Remaining",
      "gridPos": { "x": 20, "y": 3, "w": 4, "h": 3 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_BMS}" },
      "targets": [
        {
          "refId": "A",
          "rawQuery": true,
          "query": "SELECT last(\"remaining_ah\") FROM \"bms_live\" WHERE $timeFilter",
          "resultFormat": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "amph",
          "decimals": 2,
          "color": { "mode": "fixed", "fixedColor": "#16a34a" }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "value",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Power flow — current (A) and power (W)",
      "gridPos": { "x": 0, "y": 6, "w": 24, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_BMS}" },
      "targets": [
        {
          "refId": "A",
          "rawQuery": true,
          "query": "SELECT mean(\"current_a\") AS \"Current\" FROM \"bms_live\" WHERE $timeFilter GROUP BY time($__interval) fill(null)",
          "resultFormat": "time_series"
        },
        {
          "refId": "B",
          "rawQuery": true,
          "query": "SELECT mean(\"power_w\") AS \"Power\" FROM \"bms_live\" WHERE $timeFilter GROUP BY time($__interval) fill(null)",
          "resultFormat": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 20,
            "gradientMode": "opacity",
            "spanNulls": false,
            "showPoints": "never",
            "axisPlacement": "auto",
            "thresholdsStyle": { "mode": "line" }
          },
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "transparent", "value": null },
              { "color": "#6b7280", "value": 0 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Current" },
            "properties": [
              { "id": "unit", "value": "amp" },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#3b82f6" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Power" },
            "properties": [
              { "id": "unit", "value": "watt" },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#fb923c" } },
              { "id": "custom.axisPlacement", "value": "right" }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "min", "max", "mean"] }
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Per-cell voltages (with running delta)",
      "gridPos": { "x": 0, "y": 14, "w": 14, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_BMS}" },
      "targets": [
        {
          "refId": "A",
          "rawQuery": true,
          "query": "SELECT mean(\"voltage_v\") FROM \"bms_cells\" WHERE $timeFilter GROUP BY time($__interval), \"cell_idx\" fill(previous)",
          "resultFormat": "time_series",
          "alias": "Cell $tag_cell_idx"
        },
        {
          "refId": "B",
          "rawQuery": true,
          "query": "SELECT mean(\"cell_delta_v\") * 1000 AS \"Delta\" FROM \"bms_state\" WHERE $timeFilter GROUP BY time($__interval) fill(previous)",
          "resultFormat": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "volt",
          "decimals": 3,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "fillOpacity": 0,
            "spanNulls": true,
            "showPoints": "never"
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Delta" },
            "properties": [
              { "id": "unit", "value": "mvolt" },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#facc15" } },
              { "id": "custom.axisPlacement", "value": "right" },
              { "id": "custom.drawStyle", "value": "line" },
              { "id": "custom.lineInterpolation", "value": "smooth" },
              { "id": "custom.lineWidth", "value": 2 },
              { "id": "custom.fillOpacity", "value": 12 },
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [6, 4] } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "min", "max"] }
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Temperatures",
      "gridPos": { "x": 14, "y": 14, "w": 10, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_BMS}" },
      "targets": [
        {
          "refId": "A",
          "rawQuery": true,
          "query": "SELECT mean(\"temp_c\") FROM \"bms_temps\" WHERE $timeFilter GROUP BY time($__interval), \"ntc_idx\" fill(previous)",
          "resultFormat": "time_series",
          "alias": "NTC $tag_ntc_idx"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "decimals": 1,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "opacity",
            "spanNulls": true,
            "showPoints": "never"
          },
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#16a34a", "value": null },
              { "color": "#fb923c", "value": 45 },
              { "color": "#dc2626", "value": 55 }
            ]
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "min", "max"] }
      }
    },
    {
      "id": 11,
      "type": "state-timeline",
      "title": "MOSFETs / Balance / Protection",
      "gridPos": { "x": 0, "y": 22, "w": 24, "h": 4 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_BMS}" },
      "targets": [
        {
          "refId": "A",
          "rawQuery": true,
          "query": "SELECT last(\"charging_mosfet\") AS \"Charge MOS\", last(\"discharging_mosfet\") AS \"Discharge MOS\", last(\"balance_active\") AS \"Balancing\", last(\"protection_active\") AS \"Protection\" FROM \"bms_live\" WHERE $timeFilter GROUP BY time($__interval) fill(previous)",
          "resultFormat": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 0, "fillOpacity": 90 },
          "mappings": [
            { "type": "value", "options": { "0": { "color": "#6b7280", "text": "OFF", "index": 0 } } },
            { "type": "value", "options": { "1": { "color": "#16a34a", "text": "ON", "index": 1 } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "#6b7280", "value": null }, { "color": "#16a34a", "value": 1 } ] }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Protection" },
            "properties": [
              { "id": "mappings", "value": [
                { "type": "value", "options": { "0": { "color": "#16a34a", "text": "OK",    "index": 0 } } },
                { "type": "value", "options": { "1": { "color": "#dc2626", "text": "FAULT", "index": 1 } } }
              ] }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Balancing" },
            "properties": [
              { "id": "mappings", "value": [
                { "type": "value", "options": { "0": { "color": "#6b7280", "text": "—",   "index": 0 } } },
                { "type": "value", "options": { "1": { "color": "#facc15", "text": "BAL", "index": 1 } } }
              ] }
            ]
          }
        ]
      },
      "options": {
        "showValue": "auto",
        "alignValue": "left",
        "rowHeight": 0.9,
        "mergeValues": true,
        "legend": { "showLegend": true, "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      }
    },
    {
      "id": 12,
      "type": "stat",
      "title": "Cycles",
      "gridPos": { "x": 0, "y": 26, "w": 6, "h": 3 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_BMS}" },
      "targets": [
        {
          "refId": "A",
          "rawQuery": true,
          "query": "SELECT last(\"cycle_count\") FROM \"bms_meta\"",
          "resultFormat": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "none", "decimals": 0, "color": { "mode": "fixed", "fixedColor": "#3b82f6" } }
      },
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "center", "textMode": "value" }
    },
    {
      "id": 13,
      "type": "stat",
      "title": "Nominal capacity",
      "gridPos": { "x": 6, "y": 26, "w": 6, "h": 3 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_BMS}" },
      "targets": [
        {
          "refId": "A",
          "rawQuery": true,
          "query": "SELECT last(\"capacity_ah\") FROM \"bms_meta\"",
          "resultFormat": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "amph", "decimals": 1, "color": { "mode": "fixed", "fixedColor": "#3b82f6" } }
      },
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "center", "textMode": "value" }
    },
    {
      "id": 14,
      "type": "stat",
      "title": "Cells",
      "gridPos": { "x": 12, "y": 26, "w": 6, "h": 3 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_BMS}" },
      "targets": [
        {
          "refId": "A",
          "rawQuery": true,
          "query": "SELECT last(\"cell_count\") FROM \"bms_meta\"",
          "resultFormat": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "none", "decimals": 0, "color": { "mode": "fixed", "fixedColor": "#a855f7" } }
      },
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "center", "textMode": "value" }
    },
    {
      "id": 15,
      "type": "stat",
      "title": "NTC sensors",
      "gridPos": { "x": 18, "y": 26, "w": 6, "h": 3 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_BMS}" },
      "targets": [
        {
          "refId": "A",
          "rawQuery": true,
          "query": "SELECT last(\"ntc_count\") FROM \"bms_meta\"",
          "resultFormat": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "none", "decimals": 0, "color": { "mode": "fixed", "fixedColor": "#a855f7" } }
      },
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "center", "textMode": "value" }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["bms", "conexpro", "jbd", "lifepo4"],
  "templating": { "list": [] },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Conexpro BMS",
  "uid": "conexpro-bms",
  "version": 2,
  "weekStart": "",
  "__inputs": [
    {
      "name": "DS_INFLUXDB_BMS",
      "label": "InfluxDB BMS",
      "description": "InfluxDB 1.x datasource pointing at the bms database",
      "type": "datasource",
      "pluginId": "influxdb",
      "pluginName": "InfluxDB"
    }
  ]
}
