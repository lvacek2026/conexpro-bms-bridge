# Copy to `.env` and fill in for your deployment.
# `.env` is git-ignored so secrets / per-host MAC stay local.
#
# IMPORTANT: docker-compose `env_file` parses values verbatim — do NOT put
# inline `# comment` after a value, the comment becomes part of the string.
# Use full-line comments only.

# ── BMS targeting ──────────────────────────────────────────────────────────
# Set BMS_MAC if you want to pin a specific battery (recommended once you've
# scanned and identified yours). If empty, the bridge picks the first BLE
# device whose advertised name starts with BMS_NAME_PREFIX.
#
# Discover the MAC with:    bluetoothctl scan on    (look for JBD-…/xiaoxiang/…)
BMS_MAC=
BMS_NAME_PREFIX=JBD

# ── Polling / connection ───────────────────────────────────────────────────
# Seconds between full reads
POLL_INTERVAL=30
# Seconds to wait before retrying after disconnect
CONN_RETRY=10
# Per-register response timeout
READ_TIMEOUT=5

# Comma-separated list of registers to read. Names: basic, cells, hw_version,
# manufacturer. Hex (e.g. 0x03) also works. The default trio is what most JBD
# firmwares support reliably; add `manufacturer` if yours speaks 0xA0. The
# bridge auto-disables a register after the BMS rejects it once.
REGISTERS=basic,cells,hw_version

# ── MQTT broker ────────────────────────────────────────────────────────────
MQTT_HOST=127.0.0.1
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
# State goes to <topic>/state, availability to <topic>/availability
MQTT_TOPIC=bms/main
MQTT_QOS=0
MQTT_RETAIN=true

# ── Home Assistant MQTT auto-discovery (optional) ──────────────────────────
# When HA_DISCOVERY=true, the bridge publishes retained MQTT-discovery configs
# under <HA_DISCOVERY_PREFIX>/sensor/... so HA auto-creates entities. Useful
# if you consume in HA. If you wire data via Node-RED yourself, leave off.
HA_DISCOVERY=false
HA_DISCOVERY_PREFIX=homeassistant
HA_DEVICE_NAME=Conexpro BMS

LOG_LEVEL=INFO
TZ=Europe/Prague
